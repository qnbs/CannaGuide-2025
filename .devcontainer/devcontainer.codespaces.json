{
  "name": "CannaGuide 2025 (Codespaces)",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "remoteUser": "node",
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  "forwardPorts": [5173, 3001, 3002],
  "portsAttributes": {
    "5173": { "label": "Vite Dev Server", "onAutoForward": "openBrowser" },
    "3001": { "label": "ESP32 Sensor Mock", "onAutoForward": "silent" },
    "3002": { "label": "Tauri IPC Mock", "onAutoForward": "silent" }
  },
  "containerEnv": {
    "VITE_ESP32_URL": "http://localhost:3001",
    "VITE_TAURI_MOCK_URL": "http://localhost:3002"
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "bash .devcontainer/start.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  }
}