# Stryker mutation testing artifacts
.stryker-tmp/
stryker-setup-*.js
stryker.log
reports/mutation/

# Graphify AST cache (regrows every run — do not commit)
graphify-out/cache/

# Codegraph micro context layer (regenerated locally by scripts/codegraph.mjs — do not commit)
.ai-context/

# Claude Code worktrees. These are full checkouts of this repo living inside the
# repo, so an unqualified `git add -A` in the main checkout stages one as an
# embedded git repository ("you've added another git repository inside your
# current repository") and commits a bare gitlink.
.claude/worktrees/
