#!/bin/sh
set -e

# Lightweight pre-push gate: typecheck + lint scopes only.
# Full test suite + build run as part of the dev workflow before
# committing, so repeating them here is redundant.
# Skip with: git push --no-verify (emergency only).

echo "[pre-push] Running typecheck + lint scopes..."
pnpm exec turbo run typecheck
node ./scripts/lint-scopes.mjs
echo "[pre-push] All gates passed."
