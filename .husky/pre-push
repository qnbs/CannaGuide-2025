#!/bin/sh
set -e

# Full CI-equivalent quality gate before every push.
# Mirrors CI pipeline: identity + typecheck + tests + lint scopes + build.
# Catches TS errors, test failures, and lint regressions BEFORE they hit CI.
# Skip with: git push --no-verify (emergency only).

echo "[pre-push] Running full CI gate locally..."
pnpm run gate:push
echo "[pre-push] All gates passed."
