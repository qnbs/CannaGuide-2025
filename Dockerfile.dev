# syntax=docker/dockerfile:1.7

# ── Dev container – Vite HMR with volume-mounted source ─────────────────
FROM node:20-alpine@sha256:b88333c42c23fbd91596ebd7fd10de239cedab9617de04142dde7315e3bc0afa AS dev
WORKDIR /app

# Install dependencies first (cacheable layer)
COPY package*.json ./
RUN npm ci

# Source is volume-mounted at runtime – this COPY is a fallback
COPY . .

EXPOSE 5173

CMD ["npx", "vite", "--host", "0.0.0.0"]
