# syntax=docker/dockerfile:1.7

# ── Dev container – Vite HMR with volume-mounted source ─────────────────
FROM node:25-alpine@sha256:5209bcaca9836eb3448b650396213dbe9d9a34d31840c2ae1f206cb2986a8543 AS dev
WORKDIR /app

# Install dependencies first (cacheable layer)
COPY package*.json ./
RUN npm ci

# Source is volume-mounted at runtime – this COPY is a fallback
COPY . .

USER node

EXPOSE 5173

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD node -e "fetch('http://localhost:5173/').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["npx", "vite", "--host", "0.0.0.0"]
