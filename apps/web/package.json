{
    "name": "@cannaguide/web",
    "version": "1.2.0-alpha",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:gh": "vite build && cp dist/index.html dist/404.html",
        "build:docker": "BUILD_BASE_PATH=/ vite build",
        "build:analyze": "ANALYZE=1 vite build --sourcemap",
        "preview": "vite preview",
        "typecheck": "node ../../scripts/typecheck-filter.mjs",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test -c playwright.config.ts",
        "test:e2e:install": "playwright install chromium firefox webkit",
        "test:e2e:install:ci": "playwright install --with-deps chromium firefox webkit",
        "test:ct": "playwright test -c playwright-ct.config.ts",
        "test:e2e:deploy": "playwright test -c playwright.deploy.config.ts",
        "test:fuzz": "vitest run fuzz",
        "lint": "eslint . --report-unused-disable-directives"
    },
    "dependencies": {
        "@cannaguide/ai-core": "*",
        "@cannaguide/ui": "*",
        "@google/genai": "^1.47.0",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-visually-hidden": "^1.2.4",
        "@reduxjs/toolkit": "^2.11.2",
        "@sentry/react": "^10.46.0",
        "browser-image-compression": "^2.0.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "d3": "^7.9.0",
        "dompurify": "^3.3.3",
        "html2canvas": "^1.4.1",
        "i18next": "^26.0.3",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.7",
        "mqtt": "^5.15.0",
        "qrcode.react": "^4.2.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-i18next": "^17.0.2",
        "react-redux": "^9.2.0",
        "recharts": "^3.8.1",
        "tailwind-merge": "^3.5.0",
        "three": "^0.180.0",
        "zod": "^3.25.76",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.1",
        "@capacitor/cli": "^8.3.0",
        "@playwright/experimental-ct-react": "^1.58.2",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/typography": "^0.5.19",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/d3": "^7.4.3",
        "@types/d3-hierarchy": "^3.1.7",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.2.0",
        "@vitest/coverage-v8": "^4.1.2",
        "autoprefixer": "^10.4.27",
        "babel-plugin-react-compiler": "19.1.0-rc.3",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "fake-indexeddb": "^6.2.5",
        "fast-check": "^4.6.0",
        "jsdom": "^24.1.3",
        "msw": "^2.12.14",
        "postcss": "^8.5.8",
        "rollup-plugin-visualizer": "^7.0.1",
        "source-map-explorer": "^2.5.3",
        "tailwindcss": "^3.4.19",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^4.1.0"
    }
}
