{
    "name": "@cannaguide/web",
    "version": "1.9.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:gh": "vite build && cp dist/index.html dist/404.html",
        "build:analyze": "ANALYZE=1 vite build --sourcemap",
        "analyze:sme": "source-map-explorer 'dist/assets/index-*.js'",
        "preview": "vite preview",
        "typecheck": "node ../../scripts/typecheck-filter.mjs",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test -c playwright.config.ts",
        "test:e2e:install": "playwright install chromium firefox webkit",
        "test:e2e:deps:ci": "playwright install-deps chromium firefox webkit",
        "test:e2e:deps:chromium": "playwright install-deps chromium",
        "test:e2e:install:ci": "playwright install chromium firefox webkit",
        "test:e2e:install:chromium:ci": "playwright install chromium",
        "test:ct": "playwright test -c playwright-ct.config.ts",
        "test:e2e:deploy": "playwright test -c playwright.deploy.config.ts",
        "test:fuzz": "vitest run fuzz",
        "lint": "eslint . --report-unused-disable-directives"
    },
    "dependencies": {
        "@cannaguide/ai-core": "workspace:*",
        "@cannaguide/ui": "workspace:*",
        "@google/genai": "^2.10.0",
        "@radix-ui/react-dialog": "^1.1.18",
        "@radix-ui/react-dropdown-menu": "^2.1.19",
        "@radix-ui/react-select": "^2.3.2",
        "@radix-ui/react-slot": "^1.3.0",
        "@radix-ui/react-visually-hidden": "^1.2.7",
        "@reduxjs/toolkit": "^2.12.0",
        "@sentry/react": "^10.62.0",
        "browser-image-compression": "^2.0.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "d3": "^7.9.0",
        "dompurify": "^3.4.11",
        "html-parse-stringify": "^3.0.1",
        "html2canvas": "^1.4.1",
        "html5-qrcode": "^2.3.8",
        "i18next": "^26.3.3",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.8",
        "jszip": "^3.10.1",
        "mqtt": "^5.15.0",
        "qrcode.react": "^4.2.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-i18next": "^17.0.8",
        "react-redux": "^9.3.0",
        "recharts": "^3.9.1",
        "tailwind-merge": "^3.6.0",
        "three": "^0.185.0",
        "y-indexeddb": "^9.0.12",
        "yjs": "^13.6.30",
        "zod": "^4.4.2",
        "zustand": "^5.0.14"
    },
    "optionalDependencies": {
        "@picovoice/porcupine-web": "^4.0.1",
        "@picovoice/web-voice-processor": "^4.0.10"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.12.1",
        "@playwright/experimental-ct-react": "^1.61.1",
        "@playwright/test": "^1.61.1",
        "@rolldown/plugin-babel": "^0.2.3",
        "@stryker-mutator/core": "^9.6.1",
        "@stryker-mutator/typescript-checker": "^9.6.1",
        "@stryker-mutator/vitest-runner": "^9.6.1",
        "@tailwindcss/postcss": "^4.3.1",
        "@tailwindcss/typography": "^0.5.20",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/d3": "^7.4.3",
        "@types/d3-hierarchy": "^3.1.7",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/three": "^0.185.0",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/coverage-v8": "^4.1.9",
        "babel-plugin-react-compiler": "19.1.0-rc.3",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "fake-indexeddb": "^6.2.5",
        "fast-check": "^4.8.0",
        "jsdom": "^29.1.1",
        "msw": "^2.14.6",
        "postcss": "^8.5.16",
        "rollup-plugin-visualizer": "^7.0.1",
        "source-map-explorer": "^2.5.3",
        "tailwindcss": "^4.3.2",
        "vite": "^8.1.0",
        "vite-plugin-pwa": "^1.3.0",
        "vitest": "^4.1.9"
    }
}
