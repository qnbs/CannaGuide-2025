{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*",
      "!!**/dist",
      "!!**/coverage",
      "!!**/node_modules",
      "!!**/test-results",
      "!!**/artifacts",
      "!!**/.stryker-tmp",
      "!!**/.lighthouseci"
    ]
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 100,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
