{
    "mcpServers": {
        "graphify": {
            "command": "node",
            "args": ["scripts/graphify-mcp-launcher.mjs"],
            "cwd": "${workspaceFolder}"
        },
        "gitkraken": {
            "command": "node",
            "args": ["scripts/gitkraken-mcp-launcher.mjs"],
            "cwd": "${workspaceFolder}"
        }
    },
    "projectContext": {
        "manifest": ".cursor/index.mdc",
        "rulesIndex": ".cursor/rules/index.mdc",
        "rulesDir": ".cursor/rules",
        "consciousnessStream": ".notes/meeting_notes.md",
        "preflightScripts": ["pnpm run windows:doctor", "pnpm run mdc:e2e", "pnpm run mcp:doctor"]
    }
}
