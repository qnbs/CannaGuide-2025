{
    "ci": {
        "collect": {
            "numberOfRuns": 3,
            "settings": {
                "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
            },
            "startServerCommand": "npx vite preview --port 9222",
            "startServerReadyPattern": "Local:",
            "url": ["http://localhost:9222/CannaGuide-2025/"]
        },
        "upload": {
            "target": "temporary-public-storage"
        }
    }
}
