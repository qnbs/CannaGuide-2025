{
    "name": "cannaguide-2025",
    "description": "AI-powered cannabis cultivation guide – plant tracker, 700+ strain encyclopedia, VPD calculator, breeding simulator, Gemini AI mentor & offline-first PWA.",
    "private": true,
    "version": "1.1.0",
    "packageManager": "npm@10.8.2",
    "homepage": "https://qnbs.github.io/CannaGuide-2025/",
    "type": "module",
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "keywords": [
        "cannabis",
        "cultivation",
        "grow-guide",
        "plant-tracker",
        "strain-encyclopedia",
        "vpd-calculator",
        "breeding-simulator",
        "gemini-ai",
        "pwa",
        "offline-first",
        "react",
        "typescript",
        "i18n"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:analyze": "ANALYZE=1 vite build --sourcemap",
        "build:sourcemap": "vite build --sourcemap",
        "build:gh": "vite build && cp dist/index.html dist/404.html",
        "build:docker": "BUILD_BASE_PATH=/ vite build",
        "turbo:build": "turbo run build",
        "turbo:test": "turbo run test",
        "turbo:lint": "turbo run lint",
        "turbo:typecheck": "turbo run typecheck",
        "typecheck": "tsc --noEmit",
        "turbo:tauri:build": "turbo run tauri:build",
        "bundle:visualize": "ANALYZE=1 vite build --sourcemap",
        "bundle:explore": "node ./scripts/explore-bundle.mjs",
        "benchmark": "npm run build:analyze && npm run bundle:explore",
        "biome:check": "biome check .",
        "biome:format": "biome format --write .",
        "depcheck": "depcheck --ignore-dirs=dist,coverage,node_modules,test-results,artifacts,.stryker-tmp,.lighthouseci --ignores=@biomejs/biome,@capacitor/cli,@lhci/cli,@stryker-mutator/core,@stryker-mutator/typescript-checker,@stryker-mutator/vitest-runner,@testing-library/user-event,@vitest/coverage-v8,autoprefixer,babel-plugin-react-compiler,depcheck,postcss,prettier,source-map-explorer,onnxruntime-web,@aikidosec/safe-chain,@commitlint/cli,@commitlint/config-conventional,@socketsecurity/cli,@types/d3-hierarchy,anti-trojan-source,husky,lint-staged,snyk --specials=typescript,eslint,postcss,webpack",
        "lint": "node ./scripts/lint-changed.mjs",
        "lint:changed": "node ./scripts/lint-changed.mjs",
        "lint:scopes": "node ./scripts/lint-scopes.mjs",
        "lint:full": "eslint . --report-unused-disable-directives",
        "lint:strict": "eslint . --report-unused-disable-directives --quiet",
        "strains:merge": "node ./scripts/merge-strains.mjs",
        "strains:check-new-duplicates": "node ./scripts/check-new-strain-duplicates.mjs",
        "format": "prettier --write .",
        "preview": "vite preview",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "test:e2e:install": "playwright install chromium",
        "test:e2e:install:ci": "playwright install --with-deps chromium",
        "test:e2e:deploy": "playwright test -c playwright.deploy.config.ts",
        "test:e2e": "playwright test -c playwright.config.ts",
        "test:ct": "playwright test -c playwright-ct.config.ts",
        "lighthouse:ci": "lhci autorun",
        "test:mutation": "stryker run",
        "prepare": "husky",
        "security:prettier": "prettier --check .",
        "security:trojan-source": "node ./scripts/security/trojan-source.mjs",
        "security:eslint": "eslint . --report-unused-disable-directives",
        "security:pre-commit": "pre-commit run --all-files",
        "security:secrets": "gitleaks detect --source . --no-banner --redact --config .gitleaks.toml",
        "security:semgrep": "semgrep scan --config auto --error --metrics=off",
        "security:socket": "socket npm audit",
        "security:snyk": "snyk test --all-projects --severity-threshold=high",
        "security:trivy": "trivy fs --scanners secret,misconfig,vuln --severity HIGH,CRITICAL --skip-dirs node_modules,dist,coverage,artifacts,test-results,.lighthouseci .",
        "security:scorecard": "scorecard --local . --file-mode git --format json --output scorecard.json --show-details",
        "security:alerts:report": "node ./scripts/security/update-alerts-report.mjs",
        "security:scan": "npm run security:prettier && npm run security:trojan-source && npm run security:eslint && npm run security:pre-commit && npm run security:secrets && npm run security:semgrep && npm run security:socket && npm run security:snyk && npm run security:trivy && npm run security:scorecard",
        "docker:build": "docker build -t cannaguide-2025:local .",
        "docker:run": "docker run --rm -p 8080:8080 cannaguide-2025:local",
        "tauri:dev": "npx tauri dev",
        "tauri:build": "npx tauri build",
        "cap:sync": "npx cap sync",
        "cap:open:android": "npx cap open android",
        "cap:open:ios": "npx cap open ios"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,mjs,cjs}": [
            "anti-trojan-source",
            "eslint --fix --quiet"
        ],
        "*.{json,yml,yaml,md}": [
            "anti-trojan-source",
            "prettier --write"
        ],
        "*.{html,css,toml,sh,rs}": [
            "anti-trojan-source"
        ]
    },
    "dependencies": {
        "@google/genai": "^1.46.0",
        "@mlc-ai/web-llm": "^0.2.82",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-visually-hidden": "^1.2.4",
        "@reduxjs/toolkit": "^2.11.2",
        "@sentry/react": "^10.44.0",
        "@tensorflow/tfjs": "^4.22.0",
        "@xenova/transformers": "^2.17.2",
        "browser-image-compression": "^2.0.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "d3": "^7.9.0",
        "dompurify": "^3.3.3",
        "html2canvas": "^1.4.1",
        "i18next": "^25.8.18",
        "jspdf": "^4.2.1",
        "jspdf-autotable": "^5.0.7",
        "mqtt": "^5.15.0",
        "onnxruntime-web": "^1.24.3",
        "qrcode.react": "^4.2.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-i18next": "^16.5.8",
        "react-redux": "^9.2.0",
        "recharts": "^3.8.0",
        "tailwind-merge": "^3.5.0",
        "three": "^0.180.0",
        "zod": "^3.25.76",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@aikidosec/safe-chain": "^1.4.4",
        "@axe-core/playwright": "^4.11.1",
        "@biomejs/biome": "^2.4.8",
        "@capacitor/cli": "^8.2.0",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^10.0.1",
        "@lhci/cli": "^0.15.1",
        "@playwright/experimental-ct-react": "^1.58.2",
        "@playwright/test": "^1.58.2",
        "@socketsecurity/cli": "^1.1.73",
        "@stryker-mutator/core": "^9.6.0",
        "@stryker-mutator/typescript-checker": "^9.6.0",
        "@stryker-mutator/vitest-runner": "^9.6.0",
        "@tailwindcss/typography": "^0.5.19",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/d3": "^7.4.3",
        "@types/d3-hierarchy": "^3.1.7",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "@vitejs/plugin-react": "^5.2.0",
        "@vitest/coverage-v8": "^4.1.0",
        "anti-trojan-source": "^1.8.1",
        "autoprefixer": "^10.4.27",
        "babel-plugin-react-compiler": "19.1.0-rc.3",
        "depcheck": "^1.4.7",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-anti-trojan-source": "^1.1.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "fake-indexeddb": "^6.2.5",
        "globals": "^16.5.0",
        "husky": "^9.1.7",
        "jsdom": "^24.1.3",
        "lint-staged": "^16.4.0",
        "msw": "^2.12.13",
        "postcss": "^8.5.8",
        "prettier": "^3.8.1",
        "rollup-plugin-visualizer": "^7.0.1",
        "snyk": "^1.1303.1",
        "source-map-explorer": "^2.5.3",
        "tailwindcss": "^3.4.19",
        "turbo": "^2.8.20",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^4.1.0"
    },
    "overrides": {
        "serialize-javascript": "7.0.4",
        "tmp": "0.2.5"
    }
}
