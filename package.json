{
    "name": "cannaguide-2025",
    "description": "AI-powered cannabis cultivation guide – plant tracker, 800+ strain encyclopedia, VPD calculator, breeding simulator, Gemini AI mentor & offline-first PWA.",
    "private": true,
    "version": "1.9.0",
    "packageManager": "pnpm@11.13.0",
    "engines": {
        "node": ">=24"
    },
    "homepage": "https://qnbs.github.io/CannaGuide-2025/",
    "type": "module",
    "keywords": [
        "cannabis",
        "cultivation",
        "grow-guide",
        "plant-tracker",
        "strain-encyclopedia",
        "vpd-calculator",
        "breeding-simulator",
        "gemini-ai",
        "pwa",
        "offline-first",
        "react",
        "typescript",
        "i18n"
    ],
    "scripts": {
        "dev": "turbo run dev",
        "dev:desktop": "pnpm --filter @cannaguide/desktop dev",
        "build": "turbo run build --filter=!@cannaguide/desktop",
        "build:desktop": "pnpm --filter @cannaguide/desktop build",
        "build:gh": "turbo run build:gh",
        "verify": "node ./scripts/scoped-verify.mjs typecheck",
        "verify:typecheck": "node ./scripts/scoped-verify.mjs typecheck",
        "verify:test": "node ./scripts/scoped-verify.mjs test:run",
        "verify:lint": "node ./scripts/scoped-verify.mjs lint",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "test:run": "turbo run test:run",
        "test:coverage": "turbo run test:coverage",
        "test:e2e": "pnpm --filter @cannaguide/web test:e2e",
        "test:e2e:install": "pnpm --filter @cannaguide/web test:e2e:install",
        "test:e2e:deps:ci": "pnpm --filter @cannaguide/web test:e2e:deps:ci",
        "test:e2e:deps:chromium": "pnpm --filter @cannaguide/web test:e2e:deps:chromium",
        "test:e2e:install:ci": "pnpm --filter @cannaguide/web test:e2e:install:ci",
        "test:e2e:install:chromium:ci": "pnpm --filter @cannaguide/web test:e2e:install:chromium:ci",
        "test:ct": "pnpm --filter @cannaguide/web test:ct",
        "test:mutate": "pnpm exec stryker run",
        "lint": "node ./scripts/lint-changed.mjs",
        "lint:changed": "node ./scripts/lint-changed.mjs",
        "lint:full": "eslint . --report-unused-disable-directives",
        "lint:strict": "eslint . --report-unused-disable-directives --quiet",
        "lint:scopes": "node ./scripts/lint-scopes.mjs",
        "lint:i18n": "node ./scripts/check-i18n-hardcoded.mjs",
        "check:i18n": "npx tsx ./scripts/check-i18n-completeness.mjs",
        "check:i18n-usage": "npx tsx ./scripts/check-i18n-keys-usage.mjs",
        "lint:a11y": "LINT_A11Y=1 eslint . --report-unused-disable-directives",
        "format": "prettier --write .",
        "preview": "pnpm --filter @cannaguide/web preview",
        "check:commit-identity": "node ./scripts/check-commit-identity.mjs",
        "graphify:mcp:doctor": "node ./scripts/graphify-mcp-doctor.mjs",
        "mcp:doctor": "node ./scripts/mcp-doctor.mjs",
        "windows:doctor": "node ./scripts/windows-doctor.mjs",
        "setup:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-windows.ps1",
        "devcontainer:doctor": "node ./scripts/devcontainer/doctor.mjs",
        "prettier:check:changed": "node ./scripts/prettier-check-changed.mjs",
        "strains:merge": "node ./scripts/merge-strains.mjs",
        "strains:check-new-duplicates": "node ./scripts/check-new-strain-duplicates.mjs",
        "strains:check-integrity": "node ./scripts/check-strain-integrity.mjs",
        "docs:sync-metrics": "node ./scripts/sync-doc-metrics.mjs",
        "strains:extract": "node ./scripts/extract-strains-to-json.mjs",
        "strains:generate": "node ./scripts/generate-strain-files.mjs",
        "strains:sync": "node ./scripts/extract-strains-to-json.mjs && node ./scripts/generate-strain-files.mjs",
        "strains:enrich-provenance": "node ./scripts/enrich-provenance.mjs",
        "depcheck": "depcheck --ignore-dirs=dist,coverage,node_modules,test-results,artifacts,.lighthouseci --ignores=@lhci/cli,@testing-library/user-event,@vitest/coverage-v8,autoprefixer,babel-plugin-react-compiler,depcheck,postcss,prettier,source-map-explorer,onnxruntime-web,@commitlint/cli,@commitlint/config-conventional,@socketsecurity/cli,@types/d3-hierarchy,anti-trojan-source,husky,lint-staged,snyk,conventional-changelog-cli,tsx,turbo,typedoc,typedoc-plugin-markdown --specials=typescript,eslint,postcss,webpack",
        "prepare": "husky",
        "lighthouse:ci": "lhci autorun",
        "security:prettier": "prettier --check .",
        "security:trojan-source": "node ./scripts/security/trojan-source.mjs",
        "security:eslint": "eslint . --report-unused-disable-directives",
        "security:pre-commit": "pre-commit run --all-files",
        "security:secrets": "gitleaks detect --source . --no-banner --redact --config .gitleaks.toml",
        "security:semgrep": "semgrep scan --config auto --error --metrics=off",
        "security:socket": "socket npm audit",
        "security:snyk": "snyk test --all-projects --severity-threshold=high",
        "security:grype": "grype dir:. --fail-on high --only-fixed --exclude ./node_modules --exclude ./dist --exclude ./coverage",
        "security:scorecard": "scorecard --local . --file-mode git --format json --output scorecard.json --show-details",
        "ci:audit": "node ./scripts/ci-audit-local.mjs",
        "measure:critical-path": "node ./scripts/measure-critical-path.mjs",
        "check:critical-path-coverage": "node ./scripts/check-critical-path-coverage.mjs",
        "check:file-budget": "node ./scripts/check-file-budget.mjs",
        "check:lockfile": "node ./scripts/check-pnpm-lockfile.mjs",
        "check:phantom-deps": "node ./scripts/check-phantom-deps.mjs",
        "check:localstorage": "node ./scripts/security/check-localstorage-usage.mjs",
        "gate:push": "pnpm run check:commit-identity && pnpm run lint:changed && pnpm run graphify:mcp:doctor && node ./scripts/typecheck-filter.mjs && pnpm --filter @cannaguide/web test:run && node ./scripts/lint-scopes.mjs && pnpm run check:file-budget && pnpm run build",
        "pr:push": "node ./scripts/github/pr-push.mjs",
        "security:scan": "pnpm run security:prettier && pnpm run security:trojan-source && pnpm run security:eslint && pnpm run security:pre-commit && pnpm run security:secrets && pnpm run security:semgrep && pnpm run security:socket && pnpm run security:snyk && pnpm run security:grype && pnpm run security:scorecard",
        "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
        "changelog:latest": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
        "docs:ai-core": "typedoc --entryPoints packages/ai-core/src/index.ts --out docs/api/ai-core --tsconfig packages/ai-core/tsconfig.json --plugin typedoc-plugin-markdown 2>/dev/null || typedoc --entryPoints packages/ai-core/src/index.ts --out docs/api/ai-core --tsconfig packages/ai-core/tsconfig.json"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,mjs,cjs}": [
            "anti-trojan-source",
            "eslint --fix --max-warnings 0 --no-warn-ignored"
        ],
        "*.{json,yml,yaml,md}": [
            "anti-trojan-source",
            "prettier --write"
        ],
        "*.{html,css,toml,sh,rs}": [
            "anti-trojan-source"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "^21.2.1",
        "@commitlint/config-conventional": "^21.2.0",
        "@eslint/js": "^9.39.4",
        "@lhci/cli": "^0.15.1",
        "@socketsecurity/cli": "^1.1.102",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "anti-trojan-source": "^1.12.0",
        "conventional-changelog-cli": "5.0.0",
        "depcheck": "^1.4.7",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-anti-trojan-source": "^1.1.7",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.5",
        "snyk": "^1.1306.0",
        "tsx": "^4.23.1",
        "turbo": "^2.10.5",
        "typedoc": "0.28.20",
        "typescript": "6.0.3",
        "wrangler": "^4.110.0"
    }
}
