{
    "name": "cannaguide-2025",
    "description": "AI-powered cannabis cultivation guide – plant tracker, 800+ strain encyclopedia, VPD calculator, breeding simulator, Gemini AI mentor & offline-first PWA.",
    "private": true,
    "version": "1.7.0",
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=20"
    },
    "homepage": "https://qnbs.github.io/CannaGuide-2025/",
    "type": "module",
    "keywords": [
        "cannabis",
        "cultivation",
        "grow-guide",
        "plant-tracker",
        "strain-encyclopedia",
        "vpd-calculator",
        "breeding-simulator",
        "gemini-ai",
        "pwa",
        "offline-first",
        "react",
        "typescript",
        "i18n"
    ],
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "build:gh": "turbo run build:gh",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "test:run": "turbo run test:run",
        "test:coverage": "turbo run test:coverage",
        "test:e2e": "pnpm --filter @cannaguide/web test:e2e",
        "test:e2e:install": "pnpm --filter @cannaguide/web test:e2e:install",
        "test:e2e:install:ci": "pnpm --filter @cannaguide/web test:e2e:install:ci",
        "test:ct": "pnpm --filter @cannaguide/web test:ct",
        "test:mutate": "pnpm exec stryker run",
        "lint": "node ./scripts/lint-changed.mjs",
        "lint:changed": "node ./scripts/lint-changed.mjs",
        "lint:full": "eslint . --report-unused-disable-directives",
        "lint:strict": "eslint . --report-unused-disable-directives --quiet",
        "lint:scopes": "node ./scripts/lint-scopes.mjs",
        "lint:i18n": "node ./scripts/check-i18n-hardcoded.mjs",
        "format": "prettier --write .",
        "preview": "pnpm --filter @cannaguide/web preview",
        "check:commit-identity": "node ./scripts/check-commit-identity.mjs",
        "devcontainer:doctor": "node ./scripts/devcontainer/doctor.mjs",
        "prettier:check:changed": "node ./scripts/prettier-check-changed.mjs",
        "strains:merge": "node ./scripts/merge-strains.mjs",
        "strains:check-new-duplicates": "node ./scripts/check-new-strain-duplicates.mjs",
        "strains:check-integrity": "node ./scripts/check-strain-integrity.mjs",
        "strains:extract": "node ./scripts/extract-strains-to-json.mjs",
        "strains:generate": "node ./scripts/generate-strain-files.mjs",
        "strains:sync": "node ./scripts/extract-strains-to-json.mjs && node ./scripts/generate-strain-files.mjs",
        "strains:enrich-provenance": "node ./scripts/enrich-provenance.mjs",
        "depcheck": "depcheck --ignore-dirs=dist,coverage,node_modules,test-results,artifacts,.lighthouseci --ignores=@lhci/cli,@testing-library/user-event,@vitest/coverage-v8,autoprefixer,babel-plugin-react-compiler,depcheck,postcss,prettier,source-map-explorer,onnxruntime-web,@commitlint/cli,@commitlint/config-conventional,@socketsecurity/cli,@types/d3-hierarchy,anti-trojan-source,husky,lint-staged,snyk --specials=typescript,eslint,postcss,webpack",
        "prepare": "husky",
        "lighthouse:ci": "lhci autorun",
        "security:prettier": "prettier --check .",
        "security:trojan-source": "node ./scripts/security/trojan-source.mjs",
        "security:eslint": "eslint . --report-unused-disable-directives",
        "security:pre-commit": "pre-commit run --all-files",
        "security:secrets": "gitleaks detect --source . --no-banner --redact --config .gitleaks.toml",
        "security:semgrep": "semgrep scan --config auto --error --metrics=off",
        "security:socket": "socket npm audit",
        "security:snyk": "snyk test --all-projects --severity-threshold=high",
        "security:grype": "grype dir:. --fail-on high --only-fixed --exclude ./node_modules --exclude ./dist --exclude ./coverage",
        "security:scorecard": "scorecard --local . --file-mode git --format json --output scorecard.json --show-details",
        "gate:push": "pnpm run check:commit-identity && pnpm run lint:changed && node ./scripts/typecheck-filter.mjs && pnpm --filter @cannaguide/web test:run && node ./scripts/lint-scopes.mjs && pnpm run build",
        "pr:push": "node ./scripts/github/pr-push.mjs",
        "security:scan": "pnpm run security:prettier && pnpm run security:trojan-source && pnpm run security:eslint && pnpm run security:pre-commit && pnpm run security:secrets && pnpm run security:semgrep && pnpm run security:socket && pnpm run security:snyk && pnpm run security:grype && pnpm run security:scorecard",
        "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
        "changelog:latest": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
        "docs:ai-core": "typedoc --entryPoints packages/ai-core/src/index.ts --out docs/api/ai-core --tsconfig packages/ai-core/tsconfig.json --plugin typedoc-plugin-markdown 2>/dev/null || typedoc --entryPoints packages/ai-core/src/index.ts --out docs/api/ai-core --tsconfig packages/ai-core/tsconfig.json"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,mjs,cjs}": [
            "anti-trojan-source",
            "eslint --fix --max-warnings 0 --no-warn-ignored"
        ],
        "*.{json,yml,yaml,md}": [
            "anti-trojan-source",
            "prettier --write"
        ],
        "*.{html,css,toml,sh,rs}": [
            "anti-trojan-source"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^9.39.4",
        "@lhci/cli": "^0.15.1",
        "@socketsecurity/cli": "^1.1.78",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.57.2",
        "anti-trojan-source": "^1.8.1",
        "conventional-changelog-cli": "5.0.0",
        "depcheck": "^1.4.7",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^9.1.2",
        "eslint-plugin-anti-trojan-source": "^1.1.2",
        "globals": "^16.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "snyk": "^1.1303.2",
        "turbo": "^2.9.4",
        "typedoc": "0.28.18",
        "typescript": "5.9.3"
    },
    "pnpm": {
        "overrides": {
            "@rollup/plugin-terser": "1.0.0",
            "tmp": "0.2.5",
            "lodash-es": "4.18.1",
            "lodash": ">=4.18.0",
            "basic-ftp": "5.2.2"
        },
        "onlyBuiltDependencies": [
            "esbuild",
            "sharp",
            "msw",
            "protobufjs"
        ]
    }
}
