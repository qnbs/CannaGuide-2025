{
  "name": "cannaguide-2025",
  "description": "AI-powered cannabis cultivation guide – plant tracker, 700+ strain encyclopedia, VPD calculator, breeding simulator, Gemini AI mentor & offline-first PWA.",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "keywords": [
    "cannabis",
    "cultivation",
    "grow-guide",
    "plant-tracker",
    "strain-encyclopedia",
    "vpd-calculator",
    "breeding-simulator",
    "gemini-ai",
    "pwa",
    "offline-first",
    "react",
    "typescript",
    "i18n"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "ANALYZE=1 vite build",
    "build:gh": "vite build && cp dist/index.html dist/404.html",
    "build:docker": "BUILD_BASE_PATH=/ vite build",
    "lint": "node ./scripts/lint-changed.mjs",
    "lint:changed": "node ./scripts/lint-changed.mjs",
    "lint:scopes": "node ./scripts/lint-scopes.mjs",
    "lint:full": "eslint . --report-unused-disable-directives",
    "lint:strict": "eslint . --report-unused-disable-directives --quiet",
    "strains:merge": "node ./scripts/merge-strains.mjs",
    "strains:check-new-duplicates": "node ./scripts/check-new-strain-duplicates.mjs",
    "format": "prettier --write .",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e:deploy": "playwright test -c playwright.deploy.config.ts",
    "test:e2e": "playwright test -c playwright.config.ts",
    "lighthouse:ci": "lhci autorun",
    "docker:build": "docker build -t cannaguide-2025:local .",
    "docker:run": "docker run --rm -p 8080:8080 cannaguide-2025:local",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@google/genai": "^1.19.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@reduxjs/toolkit": "^2.2.6",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3": "^7.9.0",
    "dompurify": "^3.3.2",
    "html2canvas": "^1.4.1",
    "i18next": "^25.5.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^15.0.0",
    "react-redux": "^9.1.2",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.24.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/d3": "^7.4.3",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.30.0",
    "@typescript-eslint/parser": "^8.30.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jsdom": "^24.1.0",
    "msw": "^2.12.10",
    "postcss": "^8.5.8",
    "prettier": "^3.3.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
