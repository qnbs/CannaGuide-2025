{
    "$schema": "https://schema.tauri.app/config/2",
    "identifier": "default",
    "description": "Default capability set for the CannaGuide main window. Grants minimal IPC permissions.",
    "windows": ["main"],
    "permissions": [
        "core:default",
        {
            "identifier": "core:window:default",
            "allow": [{ "window": "main" }]
        },
        "ipc:default"
    ]
}
