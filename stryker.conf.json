{
    "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
    "mutate": [
        "apps/web/stores/slices/**/*.ts",
        "apps/web/stores/useIotStore.ts",
        "apps/web/services/equipmentCalculatorService.ts",
        "apps/web/services/knowledgeCalculatorService.ts",
        "apps/web/services/knowledgeRagService.ts",
        "!apps/web/stores/slices/**/*.test.ts",
        "!apps/web/stores/**/*.test.ts"
    ],
    "testRunner": "vitest",
    "checkers": [],
    "coverageAnalysis": "off",
    "vitest": {
        "configFile": "apps/web/vite.config.ts",
        "dir": "apps/web"
    },
    "testFiles": ["apps/web/**/*.test.ts", "apps/web/**/*.test.tsx"],
    "reporters": ["clear-text", "html"],
    "htmlReporter": {
        "fileName": "reports/mutation/mutation-report.html"
    },
    "thresholds": {
        "high": 80,
        "low": 60,
        "break": 50
    },
    "concurrency": 1,
    "timeoutMS": 30000,
    "ignorePatterns": ["node_modules", "dist", ".turbo", "coverage"]
}
