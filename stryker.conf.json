{
    "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
    "mutate": [
        "apps/web/stores/slices/**/*.ts",
        "apps/web/stores/useIotStore.ts",
        "!apps/web/stores/slices/**/*.test.ts",
        "!apps/web/stores/**/*.test.ts"
    ],
    "testRunner": "vitest",
    "checkers": ["typescript"],
    "tsconfigFile": "apps/web/tsconfig.json",
    "vitest": {
        "configFile": "apps/web/vitest.config.ts"
    },
    "reporters": ["clear-text", "html"],
    "htmlReporter": {
        "fileName": "reports/mutation/mutation-report.html"
    },
    "thresholds": {
        "high": 80,
        "low": 60,
        "break": 50
    },
    "concurrency": 2,
    "timeoutMS": 30000,
    "ignorePatterns": ["node_modules", "dist", ".turbo", "coverage"]
}
