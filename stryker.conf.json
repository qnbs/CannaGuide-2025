{
    "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
    "mutate": [
        "stores/slices/**/*.ts",
        "stores/useIotStore.ts",
        "services/equipmentCalculatorService.ts",
        "services/knowledgeCalculatorService.ts",
        "services/knowledgeRagService.ts",
        "utils/lockFreeRingBuffer.ts",
        "utils/atomicsChannel.ts",
        "services/workerPool.ts",
        "!stores/slices/**/*.test.ts",
        "!stores/**/*.test.ts",
        "!utils/**/*.test.ts",
        "!services/**/*.test.ts"
    ],
    "testRunner": "vitest",
    "plugins": ["@stryker-mutator/vitest-runner"],
    "checkers": [],
    "coverageAnalysis": "all",
    "vitest": {
        "configFile": "vite.config.ts",
        "dir": "."
    },
    "testFiles": ["**/*.test.ts", "**/*.test.tsx"],
    "reporters": ["clear-text", "html"],
    "htmlReporter": {
        "fileName": "../../reports/mutation/mutation-report.html"
    },
    "thresholds": {
        "high": 80,
        "low": 60,
        "break": 50
    },
    "concurrency": 4,
    "timeoutMS": 60000,
    "incremental": true,
    "ignorePatterns": ["node_modules", "dist", ".turbo", "coverage"]
}
