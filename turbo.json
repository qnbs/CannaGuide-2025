{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"],
            "inputs": [
                "src/**",
                "components/**",
                "stores/**",
                "services/**",
                "hooks/**",
                "data/**",
                "locales/**",
                "workers/**",
                "utils/**",
                "types/**",
                "lib/**",
                "public/**",
                "vite.config.ts",
                "tsconfig.json",
                "tailwind.config.cjs",
                "postcss.config.cjs",
                "index.html",
                "index.tsx"
            ]
        },
        "dev": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true
        },
        "tauri:build": {
            "dependsOn": ["build"],
            "outputs": ["src-tauri/target/release/bundle/**"],
            "inputs": [
                "src-tauri/src/**/*.rs",
                "src-tauri/Cargo.toml",
                "src-tauri/Cargo.lock",
                "src-tauri/tauri.conf.json",
                "src-tauri/build.rs",
                "dist/**"
            ],
            "cache": false,
            "env": [
                "TAURI_SIGNING_PRIVATE_KEY",
                "TAURI_SIGNING_PRIVATE_KEY_PASSWORD",
                "TAURI_ENV_*"
            ]
        },
        "tauri:dev": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true,
            "env": ["TAURI_ENV_*"]
        },
        "test": {
            "dependsOn": ["^build"],
            "outputs": ["coverage/**"]
        },
        "test:e2e": {
            "dependsOn": ["build"],
            "outputs": ["test-results/**"]
        },
        "lint": {
            "dependsOn": ["^build"]
        },
        "lint:full": {
            "dependsOn": ["^build"]
        },
        "typecheck": {
            "dependsOn": ["^build"]
        }
    }
}
